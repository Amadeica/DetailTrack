<Window x:Class="DetailTrack.Constructors.Windows.ConstructorCreateRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Новая заявка"
        Height="550"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="📋 Создание заявки на деталь"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,20" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название детали/сборки *"
                           Margin="0,0,0,5" />
                <TextBox x:Name="TxtDetailName"
                         Height="30"
                         Margin="0,0,0,15" />

                <TextBlock Text="Тип заявки *"
                           Margin="0,0,0,5" />
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <RadioButton x:Name="RbNew"
                                 Content="Новая"
                                 IsChecked="True"
                                 Margin="0,0,20,0"
                                 GroupName="ReqType" />
                    <RadioButton x:Name="RbModification"
                                 Content="Изменение существующей"
                                 GroupName="ReqType" />
                </StackPanel>

                <TextBlock Text="Назначить технолога *"
                           Margin="0,0,0,5" />
                <ComboBox x:Name="CbTechnologists"
                          Height="30"
                          Margin="0,0,0,15"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="Id" />

                <TextBlock Text="Комментарий"
                           Margin="0,0,0,5" />
                <TextBox x:Name="TxtComment"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,15" />

                <TextBlock Text="Чертежи (можно несколько)"
                           Margin="0,0,0,5" />
                <Border BorderBrush="#BDC3C7"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <Button Content="📎 Добавить файл"
                                HorizontalAlignment="Left"
                                Padding="10,5"
                                Click="BtnAddFile_Click" />
                        <ItemsControl x:Name="IcFiles"
                                      Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,3">
                                        <TextBlock Text="📄 "
                                                   Foreground="#7F8C8D" />
                                        <TextBlock Text="{Binding FileName}"
                                                   VerticalAlignment="Center"
                                                   Margin="5,0" />
                                        <Button Content="✕"
                                                Padding="5,0"
                                                Margin="10,0,0,0"
                                                Click="BtnRemoveFile_Click"
                                                Tag="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Отмена"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click" />
            <Button Content="✅ Создать заявку"
                    Width="150"
                    Height="35"
                    Background="#27AE60"
                    Foreground="White"
                    Click="BtnCreate_Click" />
        </StackPanel>
    </Grid>
</Window>