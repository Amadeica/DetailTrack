<Window x:Class="DetailTrack.Constructors.Windows.ConstructorRequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Детали заявки"
        Height="600"
        Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock x:Name="LblTitle"
                       FontSize="18"
                       FontWeight="Bold" />
            <TextBlock x:Name="LblStatus"
                       Foreground="#7F8C8D"
                       Margin="0,5,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="📋 Информация"
                          Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Тип:"
                                   FontWeight="Bold"
                                   Grid.Row="0" />
                        <TextBlock x:Name="LblType"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Конструктор:"
                                   FontWeight="Bold"
                                   Grid.Row="1" />
                        <TextBlock x:Name="LblConstructor"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Технолог:"
                                   FontWeight="Bold"
                                   Grid.Row="2" />
                        <TextBlock x:Name="LblTechnologist"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Программист:"
                                   FontWeight="Bold"
                                   Grid.Row="3" />
                        <TextBlock x:Name="LblProgrammer"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Станок:"
                                   FontWeight="Bold"
                                   Grid.Row="4" />
                        <TextBlock x:Name="LblMachine"
                                   Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Цех:"
                                   FontWeight="Bold"
                                   Grid.Row="5" />
                        <TextBlock x:Name="LblWorkshop"
                                   Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="10,0,0,0" />

                        <TextBlock Text="Комментарий:"
                                   FontWeight="Bold"
                                   Grid.Row="6" />
                        <TextBlock x:Name="LblComment"
                                   Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="10,0,0,0"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Прикреплённые файлы">
                    <StackPanel Margin="10">
                        <ItemsControl x:Name="IcFiles">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,5">
                                        <Button Content="📥"
                                                Width="30"
                                                Margin="0,0,5,0"
                                                Click="BtnDownloadFile_Click"
                                                Tag="{Binding}" />
                                        <TextBlock Text="{Binding FileName}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding UploadedAt, StringFormat='(dd.MM.yyyy)'}"
                                                   Foreground="#7F8C8D"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="История изменений"
                          Margin="0,15,0,0">
                    <ItemsControl x:Name="IcHistory">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ECF0F1"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding ChangedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                 FontWeight="Bold" />
                                            <Run Text=" — " />
                                            <Run Text="{Binding NewStatus}"
                                                 Foreground="#27AE60" />
                                            <Run Text="{Binding Comment, StringFormat='({0})'}"
                                                 Foreground="#7F8C8D" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding ChangedBy.FullName}"
                                                   Foreground="#7F8C8D"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Закрыть"
                HorizontalAlignment="Right"
                Width="100"
                Height="35"
                Margin="0,15,0,0"
                Click="BtnClose_Click" />
    </Grid>
</Window>