<Window x:Class="DetailTrack.ToolEngineers.Windows.ToolEngineerRequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DetailTrack.ToolEngineers.Windows"
        mc:Ignorable="d"
        Title="Заявка на инструмент"
        Height="650"
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="LblTitle"
                           FontSize="18"
                           FontWeight="Bold" />
                <TextBlock x:Name="LblStatus"
                           Foreground="#7F8C8D"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <ComboBox x:Name="CbStatus"
                          Width="150"
                          Margin="0,0,10,0">
                    <ComboBoxItem Content="Создана" />
                    <ComboBoxItem Content="В закупке" />
                    <ComboBoxItem Content="Получен" />
                </ComboBox>
                <Button Content="💾 Сохранить статус"
                        Padding="10,5"
                        Background="#16A085"
                        Foreground="White"
                        Click="BtnSaveStatus_Click" />
            </StackPanel>
        </Grid>

        <GroupBox Header="📋 Информация"
                  Grid.Row="1"
                  Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Text="Инструмент:"
                           FontWeight="Bold"
                           Grid.Row="0" />
                <TextBlock x:Name="LblToolName"
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="10,0,0,0" />

                <TextBlock Text="Для детали:"
                           FontWeight="Bold"
                           Grid.Row="1" />
                <TextBlock x:Name="LblForDetail"
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="10,0,0,0" />

                <TextBlock Text="Запросил:"
                           FontWeight="Bold"
                           Grid.Row="2" />
                <TextBlock x:Name="LblRequestedBy"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="10,0,0,0" />

                <TextBlock Text="Комментарий:"
                           FontWeight="Bold"
                           Grid.Row="3" />
                <TextBlock x:Name="LblComment"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="10,0,0,0" />
            </Grid>
        </GroupBox>

        <GroupBox Header="💬 Комментарии"
                  Grid.Row="2">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <TextBox x:Name="TxtCommentInput"
                             DockPanel.Dock="Left"
                             Height="40"
                             Width="300"
                             VerticalContentAlignment="Center"
                             KeyDown="TxtComment_KeyDown" />
                    <Button Content="➕ Добавить"
                            DockPanel.Dock="Right"
                            Width="120"
                            Margin="10,0,0,0"
                            Click="BtnAddComment_Click" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              MaxHeight="300"
                              Padding="2">
                    <ItemsControl x:Name="IcComments">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ECF0F1"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding User.FullName}"
                                                 FontWeight="Bold" />
                                            <Run Text="{Binding CreatedAt, StringFormat=' (dd.MM.yyyy HH:mm)'}"
                                                 Foreground="#95A5A6" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding Text}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>

        <Button Grid.Row="3"
                Content="Закрыть"
                HorizontalAlignment="Right"
                Width="100"
                Height="35"
                Margin="0,15,0,0"
                Click="BtnClose_Click" />
    </Grid>
</Window>