<Window x:Class="DetailTrack.ToolEngineers.ToolEngineerDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DetailTrack.ToolEngineers"
        mc:Ignorable="d"
        Title="DetailTrack - Инженер по инструменту"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#16A085"
                Padding="15"
                CornerRadius="5">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="LblWelcome"
                               Text="Добро пожаловать!"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold" />
                    <TextBlock Text="Панель инженера по инструменту"
                               Foreground="White"
                               Opacity="0.9" />
                </StackPanel>
                <Button Content="🚪 Выйти"
                        HorizontalAlignment="Right"
                        Padding="12,6"
                        Click="BtnLogout_Click"
                        Background="#C0392B"
                        Foreground="White" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,15,0,10">
            <TextBlock Text="Фильтр:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <ComboBox x:Name="CbStatusFilter"
                      Width="140"
                      Margin="0,0,10,0"
                      SelectionChanged="CbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="Все статусы" />
                <ComboBoxItem Content="Создана" />
                <ComboBoxItem Content="В закупке" />
                <ComboBoxItem Content="Получен" />
            </ComboBox>

            <TextBox x:Name="TxtSearch"
                     Width="250"
                     Margin="20,0,0,0"
                     VerticalContentAlignment="Center"
                     KeyDown="TxtSearch_KeyDown" />
            <Button Content="🔍 Поиск"
                    Padding="10,5"
                    Click="BtnSearch_Click" />
            <Button Content="✕ Сброс"
                    Padding="8,5"
                    Margin="5,0,0,0"
                    Click="BtnResetSearch_Click" />
        </StackPanel>

        <!-- Таблица заявок -->
        <Grid Grid.Row="2">
            <DataGrid x:Name="DgToolRequests"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      RowHeight="35"
                      SelectionChanged="DgToolRequests_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Инструмент/Оснастка"
                                        Binding="{Binding ToolName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Статус"
                                        Binding="{Binding Status}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="Создана">
                                        <Setter Property="Foreground"
                                                Value="#E74C3C" />
                                        <Setter Property="FontWeight"
                                                Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="В закупке">
                                        <Setter Property="Foreground"
                                                Value="#F39C12" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="Получен">
                                        <Setter Property="Foreground"
                                                Value="#27AE60" />
                                        <Setter Property="FontWeight"
                                                Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Для детали"
                                        Binding="{Binding MainRequest.DetailName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Запросил"
                                        Binding="{Binding RequestedBy.FullName}"
                                        Width="150" />
                    <DataGridTextColumn Header="Дата создания"
                                        Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}"
                                        Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>