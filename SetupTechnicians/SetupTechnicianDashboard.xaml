<Window x:Class="DetailTrack.SetupTechnicians.SetupTechnicianDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DetailTrack.SetupTechnicians"
        mc:Ignorable="d"
        Title="DetailTrack - Наладчик"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="#E67E22"
                Padding="15"
                CornerRadius="5">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="LblWelcome"
                               Text="Добро пожаловать!"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold" />
                    <TextBlock Text="Панель наладчика ЧПУ"
                               Foreground="White"
                               Opacity="0.9" />
                </StackPanel>
                <Button Content="🚪 Выйти"
                        HorizontalAlignment="Right"
                        Padding="12,6"
                        Click="BtnLogout_Click"
                        Background="#C0392B"
                        Foreground="White" />
            </Grid>
        </Border>

        <!-- Фильтры -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,15,0,10">
            <TextBlock Text="Фильтр:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <ComboBox x:Name="CbStatusFilter"
                      Width="200"
                      Margin="0,0,10,0"
                      SelectionChanged="CbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="Все статусы" />
                <ComboBoxItem Content="Передано наладчику" />
                <ComboBoxItem Content="В разработке у наладчика" />
                <ComboBoxItem Content="В производстве" />
            </ComboBox>

            <TextBox x:Name="TxtSearch"
                     Width="250"
                     Margin="20,0,0,0"
                     VerticalContentAlignment="Center"
                     KeyDown="TxtSearch_KeyDown" />
            <Button Content="🔍 Поиск"
                    Padding="10,5"
                    Click="BtnSearch_Click" />
            <Button Content="✕ Сброс"
                    Padding="8,5"
                    Margin="5,0,0,0"
                    Click="BtnResetSearch_Click" />
            <CheckBox x:Name="ChkShowRemoved"
                      Content="Показать удалённые"
                      VerticalAlignment="Center"
                      Margin="20,0,0,0"
                      Checked="ChkShowRemoved_Changed"
                      Unchecked="ChkShowRemoved_Changed" />
            <Button x:Name="BtnDeleteRequest"
                    Content="🗑️ В архив"
                    Padding="10,5"
                    Margin="15,0,0,0"
                    Background="#E74C3C"
                    Foreground="White"
                    IsEnabled="False"
                    Click="BtnDeleteRequest_Click" />
        </StackPanel>

        <!-- Таблица заявок -->
        <Grid Grid.Row="2">
            <DataGrid x:Name="DgRequests"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      RowHeight="35"
                      SelectionChanged="DgRequests_SelectionChanged"
                      MouseDoubleClick="DgRequests_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№"
                                        Binding="{Binding RequestNumber}"
                                        Width="100" />
                    <DataGridTextColumn Header="Деталь"
                                        Binding="{Binding DetailName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Тип"
                                        Binding="{Binding Type}"
                                        Width="80" />
                    <DataGridTextColumn Header="Статус"
                                        Binding="{Binding Status}"
                                        Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="Передано наладчику">
                                        <Setter Property="Foreground"
                                                Value="#E74C3C" />
                                        <Setter Property="FontWeight"
                                                Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="В разработке у наладчика">
                                        <Setter Property="Foreground"
                                                Value="#F39C12" />
                                        <Setter Property="FontWeight"
                                                Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="В производстве">
                                        <Setter Property="Foreground"
                                                Value="#27AE60" />
                                        <Setter Property="FontWeight"
                                                Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Программист"
                                        Binding="{Binding Programmer.FullName}"
                                        Width="130" />
                    <DataGridTextColumn Header="Станок"
                                        Binding="{Binding MachineModel.Name}"
                                        Width="150" />
                    <DataGridTextColumn Header="Получена"
                                        Binding="{Binding ProgramUploadedAt, StringFormat='dd.MM.yyyy'}"
                                        Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>