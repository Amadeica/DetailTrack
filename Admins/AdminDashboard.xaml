<Window x:Class="DetailTrack.Admins.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DetailTrack — Администратор"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA">

    <Window.Resources>
        <Style x:Key="PrimaryButton"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#3498DB" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="Padding"
                    Value="16,8" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#2980B9" />
                </Trigger>
                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter Property="Background"
                            Value="#BDC3C7" />
                    <Setter Property="Cursor"
                            Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background"
                    Value="#27AE60" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#219A52" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background"
                    Value="#E74C3C" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#C0392B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Padding"
                    Value="12,8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#DDD" />
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBox"
               TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Padding"
                    Value="12,8" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#DDD" />
            <Setter Property="Background"
                    Value="White" />
        </Style>

        <Style x:Key="ModernComboBox"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="36" />
            <Setter Property="Padding"
                    Value="12,4" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#DDD" />
            <Setter Property="Background"
                    Value="White" />
        </Style>

        <Style x:Key="SectionTitle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Foreground"
                    Value="#2C3E50" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style x:Key="SearchTextBox"
               TargetType="TextBox"
               BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="BorderBrush"
                    Value="#3498DB" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Background"
                    Value="#FAFCFF" />
        </Style>

        <Style x:Key="UsersDataGridRow"
               TargetType="DataGridRow">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="Foreground"
                    Value="#2C3E50" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#EBF5FB" />
                </Trigger>
                <Trigger Property="IsSelected"
                         Value="True">
                    <Setter Property="Background"
                            Value="#3498DB" />
                    <Setter Property="Foreground"
                            Value="White" />
                    <Setter Property="FontWeight"
                            Value="SemiBold" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected"
                                   Value="True" />
                        <Condition Property="IsMouseOver"
                                   Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background"
                            Value="#2980B9" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#2C3E50"
                Padding="20,15"
                CornerRadius="8">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="LblWelcome"
                               Text="👨‍💼 Панель администратора"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="Управление пользователями и справочниками"
                               Foreground="White"
                               Opacity="0.85"
                               FontSize="13" />
                </StackPanel>
                <Button Content="Выйти"
                        HorizontalAlignment="Right"
                        Style="{StaticResource DangerButton}"
                        Padding="20,8"
                        Click="BtnLogout_Click" />
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding"
                            Value="20,10" />
                    <Setter Property="Foreground"
                            Value="#555" />
                    <Setter Property="FontSize"
                            Value="13" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter TargetName="Border"
                                                Property="BorderBrush"
                                                Value="#3498DB" />
                                        <Setter Property="Foreground"
                                                Value="#2C3E50" />
                                        <Setter Property="FontWeight"
                                                Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,15">
                        <Border Background="White"
                                BorderBrush="#D0D7DE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="🔍 Поиск по логину или ФИО"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#3498DB"
                                               Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtUserSearch"
                                             Style="{StaticResource SearchTextBox}"
                                             VerticalContentAlignment="Center"
                                             KeyDown="TxtUserSearch_KeyDown" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom"
                                            Margin="12,0,0,0">
                                    <Button Content="Найти"
                                            MinWidth="90"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnSearchUsers_Click" />
                                    <Button Content="Сброс"
                                            MinWidth="90"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnResetUsers_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Цех:"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,8,0" />
                            <ComboBox x:Name="CbFilterWorkshop"
                                      Width="170"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,20,0"
                                      SelectionChanged="CbUserFilter_Changed" />

                            <TextBlock Text="Специализация:"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,8,0" />
                            <ComboBox x:Name="CbFilterSpecialization"
                                      Width="190"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,20,0"
                                      SelectionChanged="CbUserFilter_Changed" />

                            <CheckBox x:Name="ChkShowInactive"
                                      Content="Показать неактивных"
                                      VerticalAlignment="Center"
                                      Checked="ChkShowInactive_Changed"
                                      Unchecked="ChkShowInactive_Changed" />
                        </StackPanel>
                    </StackPanel>

                    <DataGrid x:Name="DgUsers"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42"
                              Background="White"
                              BorderBrush="#EEE"
                              BorderThickness="1"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowStyle="{StaticResource UsersDataGridRow}">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#F1F4F6" />
                                <Setter Property="Foreground"
                                        Value="#2C3E50" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                                <Setter Property="Padding"
                                        Value="12,8" />
                                <Setter Property="BorderThickness"
                                        Value="0,0,1,0" />
                                <Setter Property="BorderBrush"
                                        Value="#E0E0E0" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"
                                        Value="12,0" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Логин"
                                                Binding="{Binding Login}"
                                                Width="110" />
                            <DataGridTextColumn Header="ФИО"
                                                Binding="{Binding FullName}"
                                                Width="*" />
                            <DataGridTextColumn Header="Роль"
                                                Binding="{Binding Role.Name}"
                                                Width="130" />
                            <DataGridTextColumn Header="Цех"
                                                Binding="{Binding Workshop.Name}"
                                                Width="110" />
                            <DataGridTextColumn Header="Специализация"
                                                Binding="{Binding Specialization.Name}"
                                                Width="140" />
                            <DataGridCheckBoxColumn Header="Активен"
                                                    Binding="{Binding IsActive}"
                                                    Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">
                        <Button Content="➕ Добавить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAddUser_Click"
                                Margin="0,0,10,0" />
                        <Button Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnEditUser_Click"
                                Margin="0,0,10,0" />
                        <Button Content="🗑️ Деактивировать"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDeleteUser_Click" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Цеха">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="ChkShowRemovedWorkshops"
                              Grid.Row="0"
                              Content="Показать удалённые"
                              Margin="0,0,0,10"
                              Checked="ChkShowRemovedWorkshops_Changed"
                              Unchecked="ChkShowRemovedWorkshops_Changed" />
                    <DataGrid x:Name="DgWorkshops"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42"
                              Background="White"
                              BorderBrush="#EEE"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название"
                                                Binding="{Binding Name}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">
                        <Button x:Name="BtnAddWorkshop"
                                Content="➕ Добавить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAdd_Click"
                                Tag="Workshop"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnEditWorkshop"
                                Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnEdit_Click"
                                Tag="Workshop"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnDeleteWorkshop"
                                Content="🗑️ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDelete_Click"
                                Tag="Workshop"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnRestoreWorkshop"
                                Content="↩️ Восстановить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnRestore_Click"
                                Tag="Workshop"
                                Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Типы станков">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <CheckBox x:Name="ChkShowRemovedMachineTypes"
                              Grid.Row="0"
                              Content="Показать удалённые"
                              Margin="0,0,0,10"
                              Checked="ChkShowRemovedMachineTypes_Changed"
                              Unchecked="ChkShowRemovedMachineTypes_Changed" />
                    <DataGrid x:Name="DgMachineTypes"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42"
                              Background="White"
                              BorderBrush="#EEE"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название"
                                                Binding="{Binding Name}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">
                        <Button x:Name="BtnAddMachineType"
                                Content="➕ Добавить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAdd_Click"
                                Tag="MachineType"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnEditMachineType"
                                Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnEdit_Click"
                                Tag="MachineType"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnDeleteMachineType"
                                Content="🗑️ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDelete_Click"
                                Tag="MachineType"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnRestoreMachineType"
                                Content="↩️ Восстановить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnRestore_Click"
                                Tag="MachineType"
                                Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Модели станков">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,10">
                        <Border Background="White"
                                BorderBrush="#D0D7DE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="🔍 Поиск по названию модели или типу станка"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#3498DB"
                                               Margin="0,0,0,6" />
                                    <TextBox x:Name="TxtMachineModelSearch"
                                             Style="{StaticResource SearchTextBox}"
                                             VerticalContentAlignment="Center"
                                             KeyDown="TxtMachineModelSearch_KeyDown" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom"
                                            Margin="12,0,0,0">
                                    <Button Content="Найти"
                                            MinWidth="90"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnSearchMachineModels_Click" />
                                    <Button Content="Сброс"
                                            MinWidth="90"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="BtnResetMachineModels_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <CheckBox x:Name="ChkShowRemovedMachineModels"
                                  Content="Показать удалённые"
                                  Checked="ChkShowRemovedMachineModels_Changed"
                                  Unchecked="ChkShowRemovedMachineModels_Changed" />
                    </StackPanel>
                    <DataGrid x:Name="DgMachineModels"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42"
                              Background="White"
                              BorderBrush="#EEE"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название"
                                                Binding="{Binding Name}"
                                                Width="*" />
                            <DataGridTextColumn Header="Тип станка"
                                                Binding="{Binding MachineType.Name}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">
                        <Button x:Name="BtnAddMachineModel"
                                Content="➕ Добавить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAdd_Click"
                                Tag="MachineModel"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnEditMachineModel"
                                Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnEdit_Click"
                                Tag="MachineModel"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnDeleteMachineModel"
                                Content="🗑️ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDelete_Click"
                                Tag="MachineModel"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnRestoreMachineModel"
                                Content="↩️ Восстановить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnRestore_Click"
                                Tag="MachineModel"
                                Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Специализации">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="DgSpecializations"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              RowHeight="42"
                              Background="White"
                              BorderBrush="#EEE"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название"
                                                Binding="{Binding Name}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,15,0,0">
                        <Button Content="➕ Добавить"
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAdd_Click"
                                Tag="Specialization"
                                Margin="0,0,10,0" />
                        <Button Content="✏️ Изменить"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnEdit_Click"
                                Tag="Specialization"
                                Margin="0,0,10,0" />
                        <Button Content="🗑️ Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDelete_Click"
                                Tag="Specialization" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>