<Window x:Class="DetailTrack.Technologists.Windows.TechnologistCreateToolRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DetailTrack.Technologists.Windows"
        mc:Ignorable="d"
        Title="Заявка на инструмент"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="🔧 Новая заявка на инструмент"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,20" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Название инструмента/оснастки *"
                       Margin="0,0,0,5" />
            <TextBox x:Name="TxtToolName"
                     Height="30"
                     Margin="0,0,0,15" />

            <TextBlock Text="Комментарий (опционально)"
                       Margin="0,0,0,5" />
            <TextBox x:Name="TxtComment"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,15" />

            <TextBlock Text="Для заявки:"
                       FontWeight="Bold"
                       Margin="0,0,0,5" />
            <TextBlock x:Name="LblForRequest"
                       Foreground="#7F8C8D" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Отмена"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click" />
            <Button Content="✅ Создать"
                    Width="120"
                    Height="35"
                    Background="#9B59B6"
                    Foreground="White"
                    Click="BtnCreate_Click" />
        </StackPanel>
    </Grid>
</Window>